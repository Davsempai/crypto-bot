# =============================================
# CRYPTO FUTURES BOT v4 — CONFIGURACIÓN
# =============================================
# Copia este archivo como .env y rellena los valores

# ── TELEGRAM ──────────────────────────────────
TELEGRAM_BOT_TOKEN=7xxxxxxxxx:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tu user ID de Telegram (separa varios con coma)
# Obtenlo hablando con @userinfobot en Telegram
AUTHORIZED_USERS=123456789

# ID del canal/grupo donde se envían señales (número negativo)
# Obtenlo reenviando un mensaje del canal a @userinfobot
SIGNAL_CHANNEL_ID=-1001234567890

# ── EXCHANGE ──────────────────────────────────
# Elige tu exchange: "weex" o "binance"
EXCHANGE=weex

# ── WEEX (si EXCHANGE=weex) ───────────────────
# Obtén las 3 claves en: weex.com → Perfil → API Management
# Permisos necesarios: solo "Read" (lectura)
WEEX_API_KEY=wx_xxxxxxxxxxxxxxxxxxxxxxxx
WEEX_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WEEX_PASSPHRASE=tu_passphrase_aqui

# ── BINANCE (si EXCHANGE=binance) ─────────────
# Solo necesario si cambias a Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=
USE_TESTNET=false

# ── ANTHROPIC (Claude AI para análisis macro) ──
# Obtén en: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx


# ── TRADING ───────────────────────────────────
# Pares a monitorear (todos disponibles en Weex Futuros USDT-M)
TRADING_PAIRS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT

# Intervalo de chequeo en segundos
CHECK_INTERVAL=60

# Umbral de funding rate para alertas (0.05 = 0.05%)
FUNDING_RATE_THRESHOLD=0.05

# Cambio de OI en 1h que dispara alerta (5 = 5%)
OI_CHANGE_THRESHOLD=5.0

# Riesgo máximo por operación en % del capital
MAX_RISK_PER_TRADE=1.0

# Modo paper trading: true = solo análisis, no opera real
PAPER_TRADING=true

# Nivel de logs: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
